# Stage 1: build
FROM node:20-alpine AS builder
WORKDIR /app

COPY weather-frontend/package*.json ./
RUN npm ci

COPY weather-frontend/vite.config.ts weather-frontend/tsconfig*.json ./
COPY weather-frontend/src ./src
COPY weather-frontend/index.html ./

RUN npm run build

# Stage 2: serve with nginx
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]